# Copy to .env and fill in. Never commit .env.

# Database (matches infra/docker-compose.dev.yml)
DATABASE_URL=postgresql://algolens:algolens@localhost:5432/algolens

# Redis / BullMQ
REDIS_URL=redis://localhost:6379

# Auth.js v5 — generate with: npx auth secret
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Magic-link email (Resend or SMTP)
AUTH_EMAIL_SERVER=
AUTH_EMAIL_FROM=

# Observability (optional — features gate behind these being set)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Judge (Phase 4 — isolated VM)
JUDGE0_URL=
JUDGE0_TOKEN=
